MARINE_CUSTOM_YOLO=D:/fish-sih-final/marine-annotation-studio/backend/best.pt
MARINE_TFLITE_MODELS=D:/fish-sih-final/marine-annotation-studio/backend/model_nano32.tflite,D:/fish-sih-final/marine-annotation-studio/backend/model32.tflite
MARINE_ENABLE_OPEN_VOCAB=true
MARINE_OPEN_VOCAB_PROMPT_MODE=generic
# generic = ~25 prompts (recommended) | full = 500+ species from CSV (slow)
MARINE_AUTO_USE_ALL_MODELS=true
MARINE_FAST_FOLDER_MODE=true
MARINE_FAST_MODE_USE_TFLITE=true
MARINE_ENABLE_CROP_CLASSIFIER=true
MARINE_FOLDER_LABEL_MODE=folder_primary
MARINE_FAST_MODE_USE_TFLITE=true
MARINE_ENABLE_CROP_CLASSIFIER=true
MARINE_OPEN_VOCAB_MODEL=yolov8s-worldv2.pt
MARINE_CONFIDENCE=0.1
MARINE_IOU_THRESHOLD=0.45
MARINE_YOLO_NMS_IOU=0.55
MARINE_CONFIDENCE=0.08
MARINE_FOLDER_LABEL_MODE=smart
MARINE_SPECIES_MAPPING_CSV=data/species_mapping.csv
MARINE_MAX_BOXES=300
MARINE_IMGSZ=1280

# Batch — accurate mode matches single-image Auto (all models + rescue + box expand)
MARINE_BATCH_ACCURATE_MODE=true
MARINE_BATCH_USE_ALL_MODELS=true
MARINE_BATCH_USE_OPEN_VOCAB=true
MARINE_BATCH_IMGSZ=960
MARINE_BATCH_ACCURATE_IMGSZ=1280
MARINE_BATCH_OPEN_VOCAB_IMGSZ=960
MARINE_BATCH_INFERENCE_SIZE=8
# MARINE_BATCH_USE_LEGACY_PIPELINE=true

# Google Drive projects (optional) — OAuth 2.0 Web client in Google Cloud Console
# Authorized redirect URI must include: http://127.0.0.1:8765/drive/oauth/callback
# MARINE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# MARINE_GOOGLE_CLIENT_SECRET=your-client-secret
# MARINE_GOOGLE_OAUTH_REDIRECT_URI=http://127.0.0.1:8765/drive/oauth/callback
# MARINE_GOOGLE_OAUTH_FRONTEND_REDIRECT=http://127.0.0.1:5173
# MARINE_DRIVE_CACHE_ENABLED=true
