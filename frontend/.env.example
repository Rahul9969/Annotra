# ── Cloud (Vercel / Netlify) ─────────────────────────────────────────────
# Required when the UI is hosted remotely. Rebuild after changing.
# VITE_API_URL=https://annotra-gzdf.onrender.com

# ── Local (default) ───────────────────────────────────────────────────────
# Leave VITE_API_URL unset — API defaults to http://127.0.0.1:8765
#   npm run dev          → Vite :5173 + backend :8765
#   npm run dev:electron → Desktop app + backend

# Optional: point a local UI build at a remote API (testing cloud backend)
# VITE_API_URL=https://annotra-gzdf.onrender.com
